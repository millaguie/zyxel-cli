#!/usr/bin/env python3
"""Standalone launcher — runs zyxel_cli directly from the repo directory.

For the packaged install, use `pipx install .` which generates its own
executable from the `zyxel-cli` console-script entry point in pyproject.toml.
"""
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from zyxel_cli.cli import main

if __name__ == "__main__":
    main()
